{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "release-type": "go",
    "include-v-in-tag": true,
    "packages": {
        ".": {
            "package-name": "dashboard",
            "changelog-sections": [
                {
                    "type": "feat",
                    "section": "Features"
                },
                {
                    "type": "fix",
                    "section": "Bug Fixes"
                },
                {
                    "type": "perf",
                    "section": "Performance"
                },
                {
                    "type": "docs",
                    "section": "Docs",
                    "hidden": true
                },
                {
                    "type": "ci",
                    "section": "CI",
                    "hidden": true
                },
                {
                    "type": "chore",
                    "section": "Chores",
                    "hidden": true
                },
                {
                    "type": "refactor",
                    "section": "Refactor",
                    "hidden": true
                },
                {
                    "type": "test",
                    "section": "Tests",
                    "hidden": true
                },
                {
                    "type": "build",
                    "section": "Build",
                    "hidden": true
                },
                {
                    "type": "style",
                    "section": "Style",
                    "hidden": true
                }
            ]
        }
    }
}